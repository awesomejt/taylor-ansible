# Hermes Agent (Nous Research) - Docker Compose
# Generated by Ansible - do not edit directly
# https://github.com/NousResearch/hermes-agent
#
# Services:
#   gateway   - Messaging gateway (Telegram, Discord, Slack, etc.)
#               Uses network_mode: host for platform connectivity
#   dashboard - Web UI for config and monitoring (localhost only by design)
#               Proxied via Nginx at hermes.taylor.lan
#   nginx     - Reverse proxy for dashboard (optional, hermes_nginx_enable)

services:
{% if hermes_gateway_enabled %}
  gateway:
    build:
      context: {{ hermes_install_dir }}/src
    image: hermes-agent:local
    container_name: hermes-gateway
    restart: {{ hermes_docker_restart_policy }}
    # Host networking is required for outbound platform connectivity
    network_mode: host
    volumes:
      - {{ hermes_data_dir }}:/opt/data
    environment:
      - HERMES_UID={{ hermes_uid }}
      - HERMES_GID={{ hermes_gid }}
    command: ["gateway", "run"]
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
{% endif %}

  dashboard:
    image: hermes-agent:local
    container_name: hermes-dashboard
    restart: {{ hermes_docker_restart_policy }}
{% if hermes_gateway_enabled %}
    depends_on:
      - gateway
{% endif %}
    expose:
      - "{{ hermes_dashboard_port }}"
    volumes:
      - {{ hermes_data_dir }}:/opt/data
    environment:
      - HERMES_UID={{ hermes_uid }}
      - HERMES_GID={{ hermes_gid }}
    command: ["dashboard", "--host", "0.0.0.0", "--port", "{{ hermes_dashboard_port }}", "--no-open"]
    networks:
      - hermes_frontend
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

{% if hermes_nginx_enable %}
  nginx:
    image: nginx:stable-alpine
    container_name: hermes-nginx
    restart: {{ hermes_docker_restart_policy }}
    depends_on:
      - dashboard
    ports:
      - "{{ hermes_nginx_http_port }}:{{ hermes_nginx_http_port }}"
{% if hermes_nginx_ssl_enable %}
      - "{{ hermes_nginx_https_port }}:{{ hermes_nginx_https_port }}"
{% endif %}
    volumes:
      - {{ hermes_install_dir }}/nginx.conf:/etc/nginx/conf.d/default.conf:ro
{% if hermes_nginx_auth_enable %}
      - {{ hermes_install_dir }}/.htpasswd:/etc/nginx/.htpasswd:ro
{% endif %}
{% if hermes_nginx_ssl_enable %}
      - {{ hermes_nginx_ssl_cert_path }}:{{ hermes_nginx_ssl_cert_path }}:ro
      - {{ hermes_nginx_ssl_key_path }}:{{ hermes_nginx_ssl_key_path }}:ro
{% endif %}
    networks:
      - hermes_frontend
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"
{% endif %}

networks:
  hermes_frontend:
    driver: bridge

