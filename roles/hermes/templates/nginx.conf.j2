# Hermes Agent - Nginx Reverse Proxy (Dashboard)
# Generated by Ansible - do not edit directly
#
# SECURITY: The Hermes dashboard stores API keys. This config includes
# HTTP Basic Auth when hermes_nginx_auth_enable is true (strongly recommended).
# Docs: https://hermes-agent.nousresearch.com/docs/

upstream hermes_dashboard {
    server dashboard:{{ hermes_dashboard_port }};
}

server {
    listen {{ hermes_nginx_http_port }};
{% if hermes_nginx_ssl_enable %}
    listen {{ hermes_nginx_https_port }} ssl http2;
{% endif %}
    server_name {{ hermes_nginx_server_name }};

    access_log /var/log/nginx/hermes_access.log;
    error_log /var/log/nginx/hermes_error.log;

{% if hermes_nginx_ssl_enable %}
    ssl_certificate {{ hermes_nginx_ssl_cert_path }};
    ssl_certificate_key {{ hermes_nginx_ssl_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;

    # Redirect HTTP to HTTPS
    if ($scheme != "https") {
        return 301 https://$server_name$request_uri;
    }
{% endif %}

{% if hermes_nginx_auth_enable %}
    # HTTP Basic Auth - protects the dashboard which stores API keys
    auth_basic "Hermes Dashboard";
    auth_basic_user_file /etc/nginx/.htpasswd;
{% endif %}

    # Allow large payloads (file uploads, long prompts)
    client_max_body_size 50M;

    location / {
        proxy_pass http://hermes_dashboard;
        proxy_http_version 1.1;

        # Standard proxy headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # WebSocket support (dashboard uses websockets for live updates)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Disable buffering for streaming responses
        proxy_buffering off;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
