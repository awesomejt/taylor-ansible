# Hermes environment for instance: {{ hermes_instance.name }}
# Managed by Ansible - do not edit manually.

# Optional fallback provider key for OpenRouter.
OPENROUTER_API_KEY={{ vault_hermes_openrouter_api_key | default('') }}

# API key for OpenAI-compatible custom endpoints (LiteLLM/oMLX).
OPENAI_API_KEY={{ vault_openwebui_litellm_master_key | default(vault_hermes_omlx_api_key | default(hermes_omlx_api_key | default(''))) }}

# SearXNG endpoint used by Hermes web_search when configured with backend=searxng.
SEARXNG_URL={{ hermes_searxng_url }}

# Fail fast on stalled providers so fallback can engage quickly.
HERMES_API_TIMEOUT={{ hermes_api_timeout_seconds }}
HERMES_API_CALL_STALE_TIMEOUT={{ hermes_api_stale_timeout_seconds }}

{% if hermes_instance.discord_enabled | default(false) | bool %}
# Discord gateway settings
DISCORD_BOT_TOKEN={{ vault_hermes_discord_tokens[hermes_instance.name] | default('') }}
DISCORD_ALLOWED_USERS={{ hermes_discord_allowed_users | default([]) | join(',') }}
DISCORD_REQUIRE_MENTION={{ hermes_instance.discord_require_mention | default(false) | bool | lower }}
DISCORD_HOME_CHANNEL={{ hermes_instance.discord_home_channel | default('') }}
# Mentionless channel is only this profile's home channel.
# Shared channels are mention-required by policy.
{% set _free_channels = [hermes_instance.discord_home_channel | default('')] | reject('equalto', '') | list | unique %}
DISCORD_FREE_RESPONSE_CHANNELS={{ _free_channels | join(',') }}
{% endif %}
