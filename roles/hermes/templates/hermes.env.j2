# Hermes environment secrets and platform toggles
# Managed by Ansible - do not edit manually.

# Optional fallback provider key for OpenRouter.
OPENROUTER_API_KEY={{ vault_hermes_openrouter_api_key | default('') }}

{% if hermes_discord_enabled | bool %}
# Discord gateway settings
DISCORD_BOT_TOKEN={{ vault_hermes_discord_token | default('') }}
DISCORD_ALLOWED_USERS={{ hermes_discord_allowed_users | default([]) | join(',') }}
DISCORD_REQUIRE_MENTION={{ hermes_discord_require_mention | bool | lower }}
DISCORD_HOME_CHANNEL={{ hermes_discord_home_channel | default('') }}
{% endif %}
