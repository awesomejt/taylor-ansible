# Hermes environment for instance: {{ hermes_instance.name }}
# Managed by Ansible - do not edit manually.

# Optional fallback provider key for OpenRouter.
OPENROUTER_API_KEY={{ vault_hermes_openrouter_api_key | default('') }}

# API key for OpenAI-compatible custom endpoints (LiteLLM/oMLX).
OPENAI_API_KEY={{ vault_openwebui_litellm_master_key | default(vault_hermes_omlx_api_key | default(hermes_omlx_api_key | default(''))) }}

# SearXNG endpoint used by Hermes web_search when configured with backend=searxng.
SEARXNG_URL={{ hermes_searxng_url }}

# AI stack service endpoints for profile tools and operator workflows.
LITELLM_BASE_URL={{ hermes_litellm_base_url }}
LITELLM_PUBLIC_URL={{ hermes_litellm_public_url | default(hermes_litellm_base_url) }}
SEARXNG_PUBLIC_URL={{ hermes_searxng_public_url | default(hermes_searxng_url) }}
OPENWEBUI_URL={{ hermes_openwebui_url }}
ANYTHINGLLM_URL={{ hermes_anythingllm_url }}
N8N_URL={{ hermes_n8n_url }}
QDRANT_URL={{ hermes_qdrant_url }}
OLLAMA_URL={{ hermes_ollama_url }}

# Shared web-memory RAG settings.
HERMES_RAG_QUERY_CMD={{ hermes_rag_query_cmd | default('/usr/local/bin/hermes-rag-query') }}
HERMES_RAG_QDRANT_URL={{ hermes_qdrant_url }}
HERMES_RAG_QDRANT_COLLECTION={{ hermes_qdrant_collection }}
HERMES_RAG_EMBED_PROVIDER={{ hermes_rag_embedding_provider | default('local-hash') }}
HERMES_RAG_EMBED_DIMENSION={{ hermes_rag_embedding_dimension | default(384) }}
HERMES_RAG_OLLAMA_URL={{ hermes_ollama_url }}
HERMES_RAG_OLLAMA_MODEL={{ hermes_rag_ollama_model | default('nomic-embed-text:latest') }}
HERMES_RAG_OLLAMA_TIMEOUT={{ hermes_rag_ollama_timeout | default(45) }}

# Compatibility variables for OpenWebUI web-memory tooling.
OWUI_WEB_MEMORY_QDRANT_URL={{ hermes_qdrant_url }}
OWUI_WEB_MEMORY_QDRANT_COLLECTION={{ hermes_qdrant_collection }}
OWUI_WEB_MEMORY_EMBEDDING_PROVIDER={{ hermes_rag_embedding_provider | default('local-hash') }}
OWUI_WEB_MEMORY_EMBEDDING_DIMENSION={{ hermes_rag_embedding_dimension | default(384) }}
OWUI_WEB_MEMORY_OLLAMA_URL={{ hermes_ollama_url }}
OWUI_WEB_MEMORY_OLLAMA_MODEL={{ hermes_rag_ollama_model | default('nomic-embed-text:latest') }}
OWUI_WEB_MEMORY_OLLAMA_TIMEOUT={{ hermes_rag_ollama_timeout | default(45) }}

# Fail fast on stalled providers so fallback can engage quickly.
HERMES_API_TIMEOUT={{ hermes_api_timeout_seconds }}
HERMES_API_CALL_STALE_TIMEOUT={{ hermes_api_stale_timeout_seconds }}

{% if hermes_instance.discord_enabled | default(false) | bool %}
# Discord gateway settings
DISCORD_BOT_TOKEN={{ vault_hermes_discord_tokens[hermes_instance.name] | default('') }}
DISCORD_ALLOWED_USERS={{ hermes_discord_allowed_users | default([]) | join(',') }}
DISCORD_REQUIRE_MENTION={{ hermes_instance.discord_require_mention | default(false) | bool | lower }}
DISCORD_HOME_CHANNEL={{ hermes_instance.discord_home_channel | default('') }}
# Mentionless channel is only this profile's home channel.
# Shared channels are mention-required by policy.
{% set _free_channels = [hermes_instance.discord_home_channel | default('')] | reject('equalto', '') | list | unique %}
DISCORD_FREE_RESPONSE_CHANNELS={{ _free_channels | join(',') }}
{% endif %}
