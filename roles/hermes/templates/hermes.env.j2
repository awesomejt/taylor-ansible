# Hermes Agent - Environment Configuration (.env)
# Generated by Ansible - do not edit directly
# This file is mounted to /opt/data/.env inside the container
# Full reference: https://github.com/NousResearch/hermes-agent/blob/main/.env.example

# =============================================================================
# LLM PROVIDER (REQUIRED)
# =============================================================================
# All LLM calls route through OpenRouter by default.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY={{ vault_hermes_openrouter_api_key }}

# =============================================================================
# TERMINAL TOOL CONFIGURATION
# =============================================================================
# Backend is set in config.yaml. Override here only if needed.
# TERMINAL_ENV={{ hermes_terminal_backend }}
TERMINAL_TIMEOUT=180
TERMINAL_LIFETIME_SECONDS=300

# =============================================================================
# MESSAGING PLATFORMS
# =============================================================================

{% if hermes_telegram_enabled %}
# Telegram - get token from @BotFather at https://t.me/BotFather
TELEGRAM_BOT_TOKEN={{ vault_hermes_telegram_bot_token }}
{% if hermes_telegram_allowed_users | length > 0 %}
TELEGRAM_ALLOWED_USERS={{ hermes_telegram_allowed_users | join(',') }}
{% endif %}
{% if hermes_telegram_home_channel %}
TELEGRAM_HOME_CHANNEL={{ hermes_telegram_home_channel }}
{% endif %}
{% endif %}

{% if hermes_discord_enabled %}
# Discord - create a bot at https://discord.com/developers/applications
DISCORD_TOKEN={{ vault_hermes_discord_token }}
{% if hermes_discord_allowed_users | length > 0 %}
DISCORD_ALLOWED_USERS={{ hermes_discord_allowed_users | join(',') }}
{% endif %}
{% endif %}

{% if hermes_slack_enabled %}
# Slack - create app at https://api.slack.com/apps
SLACK_BOT_TOKEN={{ vault_hermes_slack_bot_token }}
SLACK_APP_TOKEN={{ vault_hermes_slack_app_token }}
{% endif %}
