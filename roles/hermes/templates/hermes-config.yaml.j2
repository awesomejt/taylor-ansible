# Hermes config for instance: {{ hermes_instance.name }}
model:
  default: "{{ hermes_instance.model }}"
  provider: "{{ hermes_instance.provider }}"
  base_url: "{{ hermes_instance.base_url }}"
{% if hermes_instance.fallback_providers is defined and (hermes_instance.fallback_providers | length > 0) %}
  fallback_providers:
{% for fallback in hermes_instance.fallback_providers %}
    - provider: "{{ fallback.provider }}"
      model: "{{ fallback.model }}"
{% if fallback.base_url is defined %}
      base_url: "{{ fallback.base_url }}"
{% endif %}
{% endfor %}
{% endif %}

terminal:
  backend: "{{ hermes_terminal_backend }}"
  timeout: {{ hermes_terminal_timeout }}
  lifetime_seconds: {{ hermes_terminal_lifetime_seconds }}

group_sessions_per_user: true

agent:
  api_max_retries: {{ hermes_api_max_retries }}

platform_toolsets:
  cli: [hermes-cli]
{% if hermes_instance.discord_enabled | default(false) | bool %}
  discord: [hermes-discord]
{% endif %}
