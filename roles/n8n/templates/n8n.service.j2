[Unit]
Description=N8N Workflow Automation
After=docker.service
Requires=docker.service

[Service]
Type=exec
WorkingDirectory={{ n8n_project_dir }}
ExecStart=/usr/bin/docker compose -f {{ n8n_compose_file }} up --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ n8n_compose_file }} down
Restart=on-failure
RestartSec=10s
User={{ n8n_primary_user }}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
