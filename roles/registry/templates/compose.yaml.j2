services:
  registry:
    image: {{ registry_image }}
    container_name: {{ registry_container_name }}
    restart: unless-stopped
    environment:
      OTEL_TRACES_EXPORTER: {{ registry_otel_traces_exporter }}
    volumes:
      - {{ registry_data_dir }}:/var/lib/registry
      - {{ registry_config_path }}:/etc/distribution/config.yml:ro

  nginx:
    image: {{ registry_nginx_image }}
    container_name: {{ registry_nginx_container_name }}
    restart: unless-stopped
    depends_on:
      - registry
    ports:
      - "{{ registry_proxy_bind_address }}:{{ registry_proxy_http_port }}:80"
{% if registry_proxy_tls_enabled | bool %}
      - "{{ registry_proxy_bind_address }}:{{ registry_proxy_tls_port }}:443"
{% endif %}
    volumes:
      - {{ registry_nginx_conf_path }}:/etc/nginx/conf.d/default.conf:ro
{% if registry_proxy_tls_enabled | bool %}
      - {{ registry_certs_dir }}:/certs:ro
{% endif %}
