upstream docker_registry_backend {
  server registry:{{ registry_internal_port }};
}

server {
  listen 80;
  server_name {{ registry_proxy_server_name }};
{% if registry_proxy_tls_enabled | bool and registry_proxy_tls_force_https | bool %}
  return 301 https://$host:{{ registry_proxy_tls_port }}$request_uri;
{% else %}
  client_max_body_size 0;

  location / {
    proxy_pass http://docker_registry_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_request_buffering off;
  }

  location /v2/ {
    add_header Docker-Distribution-API-Version "registry/2.0" always;
    proxy_pass http://docker_registry_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_http_version 1.1;
    proxy_request_buffering off;
  }
{% endif %}
}
{% if registry_proxy_tls_enabled | bool %}

server {
  listen 443 ssl;
  server_name {{ registry_proxy_server_name }};

  ssl_certificate {{ registry_proxy_tls_cert_path }};
  ssl_certificate_key {{ registry_proxy_tls_key_path }};
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_prefer_server_ciphers on;

  client_max_body_size 0;

  location / {
    proxy_pass http://docker_registry_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_http_version 1.1;
    proxy_request_buffering off;
  }

  location /v2/ {
    add_header Docker-Distribution-API-Version "registry/2.0" always;
    proxy_pass http://docker_registry_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
    proxy_http_version 1.1;
    proxy_request_buffering off;
  }
}
{% endif %}
