---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: {{ k3s_headlamp_admin_sa_name }}
  namespace: {{ k3s_headlamp_namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: {{ k3s_headlamp_admin_sa_name }}
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: cluster-admin
subjects:
  - kind: ServiceAccount
    name: {{ k3s_headlamp_admin_sa_name }}
    namespace: {{ k3s_headlamp_namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: {{ k3s_headlamp_admin_token_secret_name }}
  namespace: {{ k3s_headlamp_namespace }}
  annotations:
    kubernetes.io/service-account.name: {{ k3s_headlamp_admin_sa_name }}
type: kubernetes.io/service-account-token
