#!/usr/bin/env python3
import hashlib
import json
import math
import os
import re
import sqlite3
import sys
import uuid
from datetime import datetime, timedelta, timezone
from typing import Dict, List, Tuple
from urllib.parse import urlparse

import pg8000.dbapi as pg8000
import requests
from bs4 import BeautifulSoup
from qdrant_client import QdrantClient, models


def env(name: str, default: str = "") -> str:
    return os.environ.get(name, default)


def env_int(name: str, default: int) -> int:
    value = env(name, str(default)).strip()
    try:
        return int(value)
    except ValueError:
        return default


def utcnow() -> datetime:
    return datetime.now(timezone.utc)


def normalize_query(query: str) -> str:
    return re.sub(r"\s+", " ", (query or "").strip())


def load_seed_queries(min_length: int) -> List[str]:
    raw = env("OWUI_WEB_MEMORY_SEED_QUERIES_JSON", "[]")
    try:
        values = json.loads(raw)
    except json.JSONDecodeError:
        values = []

    queries: List[str] = []
    seen = set()
    for value in values:
        q = normalize_query(str(value))
        if len(q) < min_length or q in seen:
            continue
        seen.add(q)
        queries.append(q)
    return queries


def load_recent_chat_queries(db_path: str, max_queries: int, min_length: int) -> List[str]:
    if not os.path.exists(db_path):
        return []

    conn = sqlite3.connect(db_path)
    try:
        cur = conn.cursor()
        cur.execute("SELECT chat FROM chat ORDER BY updated_at DESC LIMIT 80")
        rows = cur.fetchall()
    finally:
        conn.close()

    queries: List[str] = []
    seen = set()

    for row in rows:
        payload = row[0]
        if not payload:
            continue

        try:
            chat = json.loads(payload)
        except json.JSONDecodeError:
            continue

        messages = (((chat or {}).get("history") or {}).get("messages") or {}).values()
        sorted_messages = sorted(messages, key=lambda m: m.get("time", 0), reverse=True)

        for message in sorted_messages:
            if message.get("role") != "user":
                continue

            content = normalize_query(str(message.get("content", "")))
            if len(content) < min_length:
                continue
            if content in seen:
                continue

            seen.add(content)
            queries.append(content)
            if len(queries) >= max_queries:
                return queries

    return queries


def load_blocked_urls(path: str) -> set:
    blocked = set()
    if not path or not os.path.exists(path):
        return blocked

    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            value = line.strip()
            if value:
                blocked.add(value)
    return blocked


def search_searxng(base_url: str, query: str, timeout: int, max_results: int, user_agent: str) -> List[Dict[str, str]]:
    response = requests.get(
        base_url,
        params={"q": query, "format": "json"},
        headers={"User-Agent": user_agent},
        timeout=timeout,
    )
    response.raise_for_status()

    payload = response.json()
    results = payload.get("results", [])

    normalized: List[Dict[str, str]] = []
    for item in results:
        url = item.get("url") or item.get("link") or ""
        title = item.get("title") or ""
        snippet = item.get("content") or item.get("snippet") or ""

        url = url.strip()
        if not url.startswith("http"):
            continue

        normalized.append({"url": url, "title": title.strip(), "snippet": snippet.strip()})
        if len(normalized) >= max_results:
            break

    return normalized


def extract_text_from_html(html: str) -> Tuple[str, str]:
    soup = BeautifulSoup(html, "html.parser")
    title = ""
    if soup.title and soup.title.string:
        title = soup.title.string.strip()

    for tag in soup(["script", "style", "noscript", "svg"]):
        tag.extract()

    text = soup.get_text(separator=" ")
    text = re.sub(r"\s+", " ", text).strip()
    return title, text


def chunk_text(text: str, chunk_size: int, overlap: int, max_chunks: int) -> List[str]:
    if chunk_size <= 0:
        return []

    step = max(1, chunk_size - max(0, overlap))
    chunks: List[str] = []

    for start in range(0, len(text), step):
        chunk = text[start : start + chunk_size].strip()
        if not chunk:
            continue
        chunks.append(chunk)
        if len(chunks) >= max_chunks:
            break

    return chunks


def db_connect():
    return pg8000.connect(
        host=env("OWUI_WEB_MEMORY_DB_HOST"),
        port=env_int("OWUI_WEB_MEMORY_DB_PORT", 5432),
        database=env("OWUI_WEB_MEMORY_DB_NAME"),
        user=env("OWUI_WEB_MEMORY_DB_USER"),
        password=env("OWUI_WEB_MEMORY_DB_PASSWORD"),
    )


def ensure_schema(conn) -> None:
    cur = conn.cursor()
    try:
        cur.execute(
            """
            CREATE TABLE IF NOT EXISTS web_memory_documents (
              url TEXT PRIMARY KEY,
              domain TEXT NOT NULL,
              title TEXT,
              snippet TEXT,
              first_seen TIMESTAMPTZ NOT NULL DEFAULT NOW(),
              last_seen TIMESTAMPTZ NOT NULL DEFAULT NOW(),
              last_crawled TIMESTAMPTZ,
              content_hash TEXT,
              crawl_status TEXT NOT NULL DEFAULT 'new',
              crawl_error TEXT,
              indexed_chunks INTEGER NOT NULL DEFAULT 0
            );

            CREATE TABLE IF NOT EXISTS web_memory_queries (
              query TEXT PRIMARY KEY,
              source TEXT NOT NULL DEFAULT 'seed',
              first_seen TIMESTAMPTZ NOT NULL DEFAULT NOW(),
              last_seen TIMESTAMPTZ NOT NULL DEFAULT NOW(),
              last_run TIMESTAMPTZ
            );

            CREATE TABLE IF NOT EXISTS web_memory_query_documents (
              query TEXT NOT NULL REFERENCES web_memory_queries(query) ON DELETE CASCADE,
              url TEXT NOT NULL REFERENCES web_memory_documents(url) ON DELETE CASCADE,
              first_seen TIMESTAMPTZ NOT NULL DEFAULT NOW(),
              last_seen TIMESTAMPTZ NOT NULL DEFAULT NOW(),
              PRIMARY KEY (query, url)
            );

            CREATE INDEX IF NOT EXISTS idx_web_memory_documents_last_crawled
              ON web_memory_documents (last_crawled);
            CREATE INDEX IF NOT EXISTS idx_web_memory_documents_domain
              ON web_memory_documents (domain);
            """
        )
    finally:
        cur.close()
    conn.commit()


def upsert_query(conn, query: str, source: str) -> None:
    cur = conn.cursor()
    try:
        cur.execute(
            """
            INSERT INTO web_memory_queries (query, source, first_seen, last_seen, last_run)
            VALUES (%s, %s, NOW(), NOW(), NOW())
            ON CONFLICT (query) DO UPDATE
            SET
              source = EXCLUDED.source,
              last_seen = NOW(),
              last_run = NOW();
            """,
            (query, source),
        )
    finally:
        cur.close()


def upsert_discovery(
    conn,
    query: str,
    url: str,
    title: str,
    snippet: str,
) -> None:
    domain = urlparse(url).netloc
    cur = conn.cursor()
    try:
        cur.execute(
            """
            INSERT INTO web_memory_documents (url, domain, title, snippet, first_seen, last_seen)
            VALUES (%s, %s, %s, %s, NOW(), NOW())
            ON CONFLICT (url) DO UPDATE
            SET
              domain = EXCLUDED.domain,
              title = COALESCE(NULLIF(EXCLUDED.title, ''), web_memory_documents.title),
              snippet = COALESCE(NULLIF(EXCLUDED.snippet, ''), web_memory_documents.snippet),
              last_seen = NOW();
            """,
            (url, domain, title, snippet),
        )

        cur.execute(
            """
            INSERT INTO web_memory_query_documents (query, url, first_seen, last_seen)
            VALUES (%s, %s, NOW(), NOW())
            ON CONFLICT (query, url) DO UPDATE
            SET last_seen = NOW();
            """,
            (query, url),
        )
    finally:
        cur.close()


def get_document_state(conn, url: str):
    cur = conn.cursor()
    try:
        cur.execute(
            "SELECT content_hash, last_crawled FROM web_memory_documents WHERE url = %s",
            (url,),
        )
        row = cur.fetchone()
        if not row:
            return None, None
        return row[0], row[1]
    finally:
        cur.close()


def mark_document_status(
    conn,
    url: str,
    status: str,
    error: str,
    content_hash: str = None,
    indexed_chunks: int = 0,
) -> None:
    cur = conn.cursor()
    try:
        cur.execute(
            """
            UPDATE web_memory_documents
            SET
              last_crawled = NOW(),
              crawl_status = %s,
              crawl_error = %s,
              content_hash = COALESCE(%s, content_hash),
              indexed_chunks = %s
            WHERE url = %s;
            """,
            (status, error, content_hash, indexed_chunks, url),
        )
    finally:
        cur.close()


def _normalize_vector(vector: List[float]) -> List[float]:
    norm = math.sqrt(sum(v * v for v in vector))
    if norm == 0:
        return vector
    return [v / norm for v in vector]


def _hash_embed(text: str, dimension: int) -> List[float]:
    vector = [0.0] * max(1, dimension)
    tokens = re.findall(r"[A-Za-z0-9_]{2,}", text.lower())
    if not tokens:
        return vector

    for token in tokens:
        digest = hashlib.sha256(token.encode("utf-8")).digest()
        idx = int.from_bytes(digest[:4], "big") % len(vector)
        sign = 1.0 if (digest[4] % 2 == 0) else -1.0
        vector[idx] += sign

    return _normalize_vector(vector)


def embed_texts(
    texts: List[str],
    provider: str,
    embedding_dimension: int,
    ollama_url: str,
    ollama_model: str,
    ollama_timeout: int,
) -> List[List[float]]:
    if provider == "ollama":
        try:
            endpoint = ollama_url.rstrip("/") + "/api/embed"
            response = requests.post(
                endpoint,
                json={"model": ollama_model, "input": texts},
                timeout=ollama_timeout,
            )
            response.raise_for_status()
            data = response.json()
            embeddings = data.get("embeddings")
            if embeddings and isinstance(embeddings, list) and len(embeddings) == len(texts):
                return embeddings
        except Exception as e:
            print(f"WARN ollama /api/embed failed, trying /api/embeddings fallback :: {e}")

        try:
            vectors: List[List[float]] = []
            endpoint = ollama_url.rstrip("/") + "/api/embeddings"
            for text in texts:
                response = requests.post(
                    endpoint,
                    json={"model": ollama_model, "prompt": text},
                    timeout=ollama_timeout,
                )
                response.raise_for_status()
                data = response.json()
                embedding = data.get("embedding")
                if not embedding:
                    raise RuntimeError("Ollama embedding response missing embedding vector")
                vectors.append(embedding)
            return vectors
        except Exception as e:
            print(f"WARN ollama embedding unavailable, falling back to local hash embeddings :: {e}")

    return [_hash_embed(text, embedding_dimension) for text in texts]


def ensure_collection(client: QdrantClient, collection_name: str, vector_size: int) -> int:
    if client.collection_exists(collection_name):
        info = client.get_collection(collection_name)
        return int(info.config.params.vectors.size)

    client.create_collection(
        collection_name=collection_name,
        vectors_config=models.VectorParams(size=vector_size, distance=models.Distance.COSINE),
    )
    return vector_size


def index_document(
    client: QdrantClient,
    collection_name: str,
    url: str,
    title: str,
    domain: str,
    content_hash: str,
    chunks: List[str],
    provider: str,
    embedding_dimension: int,
    ollama_url: str,
    ollama_model: str,
    ollama_timeout: int,
) -> int:
    selector = models.FilterSelector(
        filter=models.Filter(
            must=[
                models.FieldCondition(
                    key="url",
                    match=models.MatchValue(value=url),
                )
            ]
        )
    )
    client.delete(collection_name=collection_name, points_selector=selector)

    vectors = embed_texts(
        texts=chunks,
        provider=provider,
        embedding_dimension=embedding_dimension,
        ollama_url=ollama_url,
        ollama_model=ollama_model,
        ollama_timeout=ollama_timeout,
    )
    points: List[models.PointStruct] = []

    for idx, vector in enumerate(vectors):
        point_id = str(uuid.uuid5(uuid.NAMESPACE_URL, f"{url}::chunk::{idx}"))
        payload = {
            "url": url,
            "domain": domain,
            "title": title,
            "chunk_index": idx,
            "chunk_count": len(chunks),
            "content_hash": content_hash,
            "text": chunks[idx],
            "indexed_at": utcnow().isoformat(),
        }
        points.append(
            models.PointStruct(
                id=point_id,
                vector=vector,
                payload=payload,
            )
        )

    if points:
        client.upsert(collection_name=collection_name, points=points, wait=True)

    return len(points)


def write_state(path: str) -> None:
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(str(int(datetime.now(timezone.utc).timestamp())) + "\n")


def main() -> int:
    searxng_url = env("OWUI_WEB_MEMORY_SEARXNG_URL")
    user_agent = env("OWUI_WEB_MEMORY_USER_AGENT", "OpenWebUI-WebMemory/1.0")
    timeout = env_int("OWUI_WEB_MEMORY_HTTP_TIMEOUT", 12)
    max_results_per_query = env_int("OWUI_WEB_MEMORY_MAX_RESULTS_PER_QUERY", 5)
    max_urls_per_run = env_int("OWUI_WEB_MEMORY_MAX_URLS_PER_RUN", 20)
    query_min_length = env_int("OWUI_WEB_MEMORY_QUERY_MIN_LENGTH", 10)
    max_chat_queries = env_int("OWUI_WEB_MEMORY_MAX_CHAT_QUERIES", 20)
    min_text_length = env_int("OWUI_WEB_MEMORY_MIN_TEXT_LENGTH", 500)
    max_doc_chars = env_int("OWUI_WEB_MEMORY_MAX_DOC_CHARS", 30000)
    chunk_size = env_int("OWUI_WEB_MEMORY_CHUNK_SIZE", 1200)
    chunk_overlap = env_int("OWUI_WEB_MEMORY_CHUNK_OVERLAP", 200)
    max_chunks_per_doc = env_int("OWUI_WEB_MEMORY_MAX_CHUNKS_PER_DOC", 20)
    crawl_interval_hours = env_int("OWUI_WEB_MEMORY_CRAWL_INTERVAL_HOURS", 24)

    openwebui_db_path = env("OWUI_WEB_MEMORY_OPENWEBUI_DB_PATH")
    blocked_urls_file = env("OWUI_WEB_MEMORY_BLOCKED_URLS_FILE")
    state_file = env("OWUI_WEB_MEMORY_STATE_FILE")

    qdrant_url = env("OWUI_WEB_MEMORY_QDRANT_URL")
    qdrant_collection = env("OWUI_WEB_MEMORY_QDRANT_COLLECTION")
    embedding_provider = env("OWUI_WEB_MEMORY_EMBEDDING_PROVIDER", "ollama").strip().lower()
    embedding_dimension = env_int("OWUI_WEB_MEMORY_EMBEDDING_DIMENSION", 384)
    ollama_url = env("OWUI_WEB_MEMORY_OLLAMA_URL", "http://192.168.50.51:11434")
    ollama_model = env("OWUI_WEB_MEMORY_OLLAMA_MODEL", "nomic-embed-text:latest")
    ollama_timeout = env_int("OWUI_WEB_MEMORY_OLLAMA_TIMEOUT", 45)

    if not searxng_url:
        print("ERROR missing OWUI_WEB_MEMORY_SEARXNG_URL")
        return 1

    blocked_urls = load_blocked_urls(blocked_urls_file)
    seed_queries = load_seed_queries(query_min_length)
    chat_queries = load_recent_chat_queries(openwebui_db_path, max_chat_queries, query_min_length)

    queries: List[Tuple[str, str]] = []
    seen_queries = set()

    for q in seed_queries:
        if q not in seen_queries:
            queries.append((q, "seed"))
            seen_queries.add(q)

    for q in chat_queries:
        if q not in seen_queries:
            queries.append((q, "openwebui_chat"))
            seen_queries.add(q)

    if not queries:
        write_state(state_file)
        print("SYNC_SUMMARY queries=0 searched=0 selected=0 indexed=0 blocked=0 errors=0")
        return 0

    conn = db_connect()
    ensure_schema(conn)

    selected = []
    seen_urls = set()
    searched_total = 0

    for query, source in queries:
        upsert_query(conn, query, source)
        try:
            results = search_searxng(
                base_url=searxng_url,
                query=query,
                timeout=timeout,
                max_results=max_results_per_query,
                user_agent=user_agent,
            )
        except Exception as e:
            print(f"WARN query search failed: {query} :: {e}")
            continue

        searched_total += len(results)

        for item in results:
            url = item["url"]
            upsert_discovery(conn, query, url, item.get("title", ""), item.get("snippet", ""))

            if url in seen_urls:
                continue
            if len(selected) >= max_urls_per_run:
                continue

            selected.append(item)
            seen_urls.add(url)

    conn.commit()

    qdrant = QdrantClient(url=qdrant_url, timeout=30)
    probe_vector = embed_texts(
        texts=["openwebui web memory probe"],
        provider=embedding_provider,
        embedding_dimension=embedding_dimension,
        ollama_url=ollama_url,
        ollama_model=ollama_model,
        ollama_timeout=ollama_timeout,
    )[0]
    collection_vector_size = ensure_collection(qdrant, qdrant_collection, len(probe_vector))

    indexed_count = 0
    blocked_count = 0
    error_count = 0
    recency_cutoff = utcnow() - timedelta(hours=crawl_interval_hours)

    for item in selected:
        url = item["url"]
        title = item.get("title", "")
        domain = urlparse(url).netloc

        if url in blocked_urls:
            mark_document_status(conn, url=url, status="blocked", error="blocked_by_local_registry")
            blocked_count += 1
            continue

        existing_hash, last_crawled = get_document_state(conn, url)
        if last_crawled and existing_hash and last_crawled >= recency_cutoff:
            continue

        try:
            response = requests.get(url, headers={"User-Agent": user_agent}, timeout=timeout)
            response.raise_for_status()
            parsed_title, text = extract_text_from_html(response.text)
            if parsed_title:
                title = parsed_title
            if len(text) > max_doc_chars:
                text = text[:max_doc_chars]

            if len(text) < min_text_length:
                mark_document_status(conn, url=url, status="thin_content", error=f"content_length<{min_text_length}")
                continue

            content_hash = hashlib.sha256(text.encode("utf-8")).hexdigest()
            if existing_hash and existing_hash == content_hash:
                mark_document_status(conn, url=url, status="unchanged", error="", content_hash=content_hash)
                continue

            chunks = chunk_text(
                text=text,
                chunk_size=chunk_size,
                overlap=chunk_overlap,
                max_chunks=max_chunks_per_doc,
            )
            if not chunks:
                mark_document_status(conn, url=url, status="no_chunks", error="empty_chunks")
                continue

            points = index_document(
                client=qdrant,
                collection_name=qdrant_collection,
                url=url,
                title=title,
                domain=domain,
                content_hash=content_hash,
                chunks=chunks,
                provider=embedding_provider,
                embedding_dimension=collection_vector_size,
                ollama_url=ollama_url,
                ollama_model=ollama_model,
                ollama_timeout=ollama_timeout,
            )

            mark_document_status(
                conn,
                url=url,
                status="indexed",
                error="",
                content_hash=content_hash,
                indexed_chunks=points,
            )
            indexed_count += 1
        except Exception as e:
            error_count += 1
            mark_document_status(conn, url=url, status="error", error=str(e)[:700])
            print(f"WARN indexing failed: {url} :: {e}")

    conn.commit()
    conn.close()
    write_state(state_file)

    print(
        "SYNC_SUMMARY "
        f"queries={len(queries)} "
        f"searched={searched_total} "
        f"selected={len(selected)} "
        f"indexed={indexed_count} "
        f"blocked={blocked_count} "
        f"errors={error_count}"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
