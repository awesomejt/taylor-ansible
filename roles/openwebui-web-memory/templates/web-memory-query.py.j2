#!/usr/bin/env python3
import argparse
import hashlib
import json
import math
import os
import re
import sys

import requests
from qdrant_client import QdrantClient


def env(name: str, default: str = "") -> str:
    return os.environ.get(name, default)


def env_int(name: str, default: int) -> int:
    value = env(name, str(default)).strip()
    try:
        return int(value)
    except ValueError:
        return default


def _normalize_vector(vector):
    norm = math.sqrt(sum(v * v for v in vector))
    if norm == 0:
        return vector
    return [v / norm for v in vector]


def _hash_embed(text: str, dimension: int):
    vector = [0.0] * max(1, dimension)
    tokens = re.findall(r"[A-Za-z0-9_]{2,}", text.lower())
    if not tokens:
        return vector
    for token in tokens:
        digest = hashlib.sha256(token.encode("utf-8")).digest()
        idx = int.from_bytes(digest[:4], "big") % len(vector)
        sign = 1.0 if (digest[4] % 2 == 0) else -1.0
        vector[idx] += sign
    return _normalize_vector(vector)


def build_query_vector(text: str):
    provider = env("OWUI_WEB_MEMORY_EMBEDDING_PROVIDER", "ollama").strip().lower()
    embedding_dimension = env_int("OWUI_WEB_MEMORY_EMBEDDING_DIMENSION", 384)
    ollama_url = env("OWUI_WEB_MEMORY_OLLAMA_URL", "http://192.168.50.51:11434")
    ollama_model = env("OWUI_WEB_MEMORY_OLLAMA_MODEL", "nomic-embed-text:latest")
    ollama_timeout = env_int("OWUI_WEB_MEMORY_OLLAMA_TIMEOUT", 45)

    if provider == "ollama":
        try:
            endpoint = ollama_url.rstrip("/") + "/api/embed"
            response = requests.post(
                endpoint,
                json={"model": ollama_model, "input": [text]},
                timeout=ollama_timeout,
            )
            response.raise_for_status()
            payload = response.json()
            embeddings = payload.get("embeddings")
            if embeddings and isinstance(embeddings, list) and len(embeddings) == 1:
                return embeddings[0]
        except Exception as e:
            print(f"WARN ollama /api/embed failed, trying /api/embeddings fallback :: {e}", file=sys.stderr)

        try:
            endpoint = ollama_url.rstrip("/") + "/api/embeddings"
            response = requests.post(
                endpoint,
                json={"model": ollama_model, "prompt": text},
                timeout=ollama_timeout,
            )
            response.raise_for_status()
            payload = response.json()
            embedding = payload.get("embedding")
            if embedding:
                return embedding
        except Exception as e:
            print(f"WARN ollama embedding unavailable, falling back to local hash embeddings :: {e}", file=sys.stderr)

    return _hash_embed(text, embedding_dimension)


def main() -> int:
    parser = argparse.ArgumentParser(description="Query Open WebUI web-memory vectors")
    parser.add_argument("query", type=str, help="Search query text")
    parser.add_argument("--top-k", type=int, default=8, help="Number of matches to return")
    args = parser.parse_args()

    qdrant_url = env("OWUI_WEB_MEMORY_QDRANT_URL")
    qdrant_collection = env("OWUI_WEB_MEMORY_QDRANT_COLLECTION")

    if not qdrant_url or not qdrant_collection:
        print("Missing OWUI_WEB_MEMORY_QDRANT_URL or OWUI_WEB_MEMORY_QDRANT_COLLECTION")
        return 1

    query_text = args.query.strip()
    if not query_text:
        print("Query must not be empty")
        return 1

    vector = build_query_vector(query_text)

    client = QdrantClient(url=qdrant_url, timeout=30)
    if not client.collection_exists(qdrant_collection):
        print("Collection does not exist yet")
        return 0

    hits = client.search(
        collection_name=qdrant_collection,
        query_vector=vector,
        limit=max(1, args.top_k),
        with_payload=True,
    )

    result = []
    for hit in hits:
        payload = hit.payload or {}
        result.append(
            {
                "score": hit.score,
                "url": payload.get("url"),
                "title": payload.get("title"),
                "domain": payload.get("domain"),
                "chunk_index": payload.get("chunk_index"),
                "text": payload.get("text"),
            }
        )

    print(json.dumps(result, indent=2))
    return 0


if __name__ == "__main__":
    sys.exit(main())
