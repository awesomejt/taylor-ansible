[Unit]
Description=Qdrant Vector Database
After=docker.service
Requires=docker.service

[Service]
Type=exec
WorkingDirectory={{ qdrant_project_dir }}
ExecStart=/usr/bin/docker compose -f {{ qdrant_compose_file }} up --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ qdrant_compose_file }} down
Restart=on-failure
RestartSec=10s
User={{ qdrant_primary_user }}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
