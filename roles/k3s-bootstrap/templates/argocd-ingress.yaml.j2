apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: argocd-server-ingress
  namespace: {{ k3s_argocd_namespace }}
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: {{ k3s_argocd_ingress_entrypoints }}
spec:
  ingressClassName: {{ k3s_argocd_ingress_class_name }}
  rules:
    - host: {{ k3s_argocd_ingress_host }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: argocd-server
                port:
                  number: 80
{% if k3s_argocd_ingress_tls | bool %}
  tls:
    - hosts:
        - {{ k3s_argocd_ingress_host }}
      secretName: argocd-server-tls
{% endif %}
