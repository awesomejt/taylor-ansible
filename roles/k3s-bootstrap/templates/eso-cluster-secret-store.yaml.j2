apiVersion: external-secrets.io/v1
kind: ClusterSecretStore
metadata:
  name: {{ k3s_eso_cluster_secret_store_name }}
  labels:
    app.kubernetes.io/managed-by: ansible
spec:
  provider:
    vault:
      server: "{{ k3s_eso_vault_server }}"
      path: "{{ k3s_eso_vault_kv_path }}"
      version: "v2"
      auth:
        appRole:
          path: "{{ k3s_eso_vault_approle_mount }}"
          roleId: "{{ vault_eso_role_id }}"
          secretRef:
            name: "{{ k3s_eso_approle_secret_name }}"
            namespace: "{{ k3s_eso_namespace }}"
            key: "secret-id"
      # caBundle is already base64 (slurp output) — ESO expects base64-encoded PEM
      caBundle: "{{ _step_ca_root_cert.content }}"
