apiVersion: v1
kind: Secret
metadata:
  name: {{ k3s_argocd_repo_secret_name }}
  namespace: {{ k3s_argocd_namespace }}
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: {{ k3s_argocd_gitops_repo_url }}
  sshPrivateKey: |
{% for line in (vault_argocd_gitops_repo_ssh_private_key | string).splitlines() %}
    {{ line }}
{% endfor %}
