[Unit]
Description=step-ca (Smallstep Certificate Authority)
After=network.target

[Service]
Type=simple
User={{ step_ca_user }}
Group={{ step_ca_group }}
WorkingDirectory={{ step_ca_home }}
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE
NoNewPrivileges=true
ExecStart={{ step_ca_binary_path }} {{ step_ca_config_dir }}/config/ca.json --password-file {{ step_ca_password_file }}
Restart=on-failure

[Install]
WantedBy=multi-user.target
