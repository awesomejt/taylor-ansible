[Unit]
Description=AnythingLLM Document AI Assistant
After=docker.service
Requires=docker.service

[Service]
Type=exec
WorkingDirectory={{ anythingllm_project_dir }}
ExecStart=/usr/bin/docker compose -f {{ anythingllm_compose_file }} up --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ anythingllm_compose_file }} down
Restart=on-failure
RestartSec=10s
User={{ anythingllm_primary_user }}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
