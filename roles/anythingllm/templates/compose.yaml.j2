services:
  anythingllm:
    image: {{ anythingllm_image }}
    container_name: {{ anythingllm_container_name }}
    restart: {{ anythingllm_restart_policy }}
    volumes:
      - {{ anythingllm_storage_dir }}:/app/server/storage
    environment:
      LLM_PROVIDER: "openai"
      OPEN_AI_KEY: "{{ anythingllm_litellm_api_key }}"
      OPEN_AI_BASE_PATH: "{{ anythingllm_litellm_base_url }}"
      OPEN_MODEL_PREF: "{{ anythingllm_litellm_model }}"
      EMBEDDING_ENGINE: "ollama"
      EMBEDDING_BASE_PATH: "{{ anythingllm_embedding_base_url }}"
      EMBEDDING_MODEL_PREF: "{{ anythingllm_embedding_model }}"
      VECTOR_DB: "qdrant"
      QDRANT_ENDPOINT: "{{ anythingllm_qdrant_endpoint }}"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.anythingllm.rule=Host(`{{ anythingllm_traefik_hostname }}`)"
      - "traefik.http.routers.anythingllm.entrypoints={{ anythingllm_traefik_entrypoint }}"
      - "traefik.http.services.anythingllm.loadbalancer.server.port=3001"
    networks:
      - traefik_proxy
    pull_policy: always

networks:
  traefik_proxy:
    external: true
