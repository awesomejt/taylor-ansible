[Unit]
Description=SearXNG Web Search
After=docker.service
Requires=docker.service

[Service]
Type=exec
WorkingDirectory={{ searxng_project_dir }}
ExecStart=/usr/bin/docker compose -f {{ searxng_compose_file }} up --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ searxng_compose_file }} down
Restart=on-failure
RestartSec=10s
User={{ searxng_primary_user }}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
