    ssl_certificate_key {{ nexus_nginx_ssl_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location / {
{{ nexus_proxy_headers() }}
        proxy_set_header Docker-Distribution-Api-Version "registry/2.0";
        rewrite ^/(.*)$ /repository/{{ nexus_docker_repository_name }}/$1 break;
        proxy_pass http://127.0.0.1:8081;
    }
}
{% endif %}
{% else %}
server {
    listen 80;
    server_name {{ nexus_nginx_server_name }};

    # Allow ACME challenge path if LetsEncrypt later runs
    location ^~ /.well-known/acme-challenge/ {
        root {{ webroot_path }};
    }

{% if nexus_docker_registry_enable | bool %}
