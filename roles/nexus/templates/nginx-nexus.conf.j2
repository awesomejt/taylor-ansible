
{% set webroot_path = '/var/www/letsencrypt' %}

{% macro nexus_proxy_headers() -%}
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Host $host;
    proxy_set_header X-Nexus-Request true;
    proxy_buffering off;
    proxy_request_buffering off;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    chunked_transfer_encoding on;
    proxy_read_timeout 900;
    proxy_connect_timeout 10;
    proxy_redirect off;
    client_max_body_size {{ nexus_nginx_client_max_body_size }};
{%- endmacro %}

{% if nexus_nginx_use_ssl | bool %}
server {
    listen 80;
    server_name {{ nexus_nginx_server_name }};

    # Serve ACME challenge for Let's Encrypt
    location ^~ /.well-known/acme-challenge/ {
        root {{ webroot_path }};
    }

    # Redirect other requests to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name {{ nexus_nginx_server_name }};

    ssl_certificate {{ nexus_nginx_ssl_cert }};
    ssl_certificate_key {{ nexus_nginx_ssl_key }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

{% if nexus_docker_registry_enable | bool %}
    location = /v2/ {
{{ nexus_proxy_headers() }}
        proxy_set_header Docker-Distribution-Api-Version "registry/2.0";
        proxy_pass http://127.0.0.1:8081/repository/{{ nexus_docker_repository_name }}/v2/;
    }

    location ~ ^/v2/repository/([^/]+)/(.*)$ {
{{ nexus_proxy_headers() }}
        proxy_set_header Docker-Distribution-Api-Version "registry/2.0";
        rewrite ^/v2/repository/([^/]+)/(.*)$ /repository/$1/v2/$2 break;
        proxy_pass http://127.0.0.1:8081;
    }

    location ~ ^/v2/(.*)$ {
{{ nexus_proxy_headers() }}
        proxy_set_header Docker-Distribution-Api-Version "registry/2.0";
        rewrite ^/v2/(.*)$ /repository/{{ nexus_docker_repository_name }}/v2/$1 break;
        proxy_pass http://127.0.0.1:8081;
    }
{% endif %}

    location / {
{{ nexus_proxy_headers() }}
        proxy_pass http://127.0.0.1:8081;
    }
}

{% if nexus_docker_registry_enable | bool %}
server {
    listen 80;
    server_name {{ nexus_docker_registry_host }};

    location ^~ /.well-known/acme-challenge/ {
        root {{ webroot_path }};
    }

