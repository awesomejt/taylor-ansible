[Unit]
Description=Agent Testbench
After=docker.service
Requires=docker.service

[Service]
Type=exec
WorkingDirectory={{ atb_project_dir }}
ExecStart=/usr/bin/docker compose -f {{ atb_compose_server_file }} up --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ atb_compose_server_file }} down
Restart=on-failure
RestartSec=10s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
