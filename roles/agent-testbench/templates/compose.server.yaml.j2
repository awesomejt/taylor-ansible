services:
  migrate:
    image: postgres:18
    environment:
      PGHOST: "{{ atb_db_host }}"
      PGPORT: "5432"
      PGUSER: "{{ atb_db_user }}"
      PGPASSWORD: "{{ atb_db_password }}"
      PGDATABASE: "{{ atb_db_name }}"
    command: >-
      bash -c 'for f in /docker-entrypoint-initdb.d/*.sql; do echo "Applying $$f"; psql -f "$$f"; done; echo "Migrations complete"'
    volumes:
      - ./db/migrations:/docker-entrypoint-initdb.d:ro
    networks:
      - internal
    restart: "no"

  api:
    build:
      context: ./api
    environment:
      DATABASE_URL: "postgresql://{{ atb_db_user }}:{{ atb_db_password }}@{{ atb_db_host }}:5432/{{ atb_db_name }}"
    depends_on:
      migrate:
        condition: service_completed_successfully
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ atb_api_port }}/health')"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 15s
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.atb-api.rule=Host(`{{ atb_api_hostname }}`)"
      - "traefik.http.routers.atb-api.entrypoints={{ atb_traefik_entrypoint }}"
      - "traefik.http.routers.atb-api.tls=true"
      - "traefik.http.services.atb-api.loadbalancer.server.port={{ atb_api_port }}"
    networks:
      - internal
      - {{ atb_network_name }}
    restart: unless-stopped

  web:
    build:
      context: ./web
      args:
        VITE_API_URL: "https://{{ atb_api_hostname }}"
    depends_on:
      - api
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.atb-web.rule=Host(`{{ atb_web_hostname }}`)"
      - "traefik.http.routers.atb-web.entrypoints={{ atb_traefik_entrypoint }}"
      - "traefik.http.routers.atb-web.tls=true"
      - "traefik.http.services.atb-web.loadbalancer.server.port={{ atb_web_port }}"
    networks:
      - internal
      - {{ atb_network_name }}
    restart: unless-stopped

networks:
  internal:
    driver: bridge
  {{ atb_network_name }}:
    external: true
