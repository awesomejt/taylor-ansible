[Unit]
Description=Ollama Docker Compose Service
After=docker.service
Requires=docker.service

[Service]
Type=exec
WorkingDirectory={{ ollama_project_dir }}
ExecStart=/usr/bin/docker compose -f {{ ollama_compose_file }} up --remove-orphans
ExecStop=/usr/bin/docker compose -f {{ ollama_compose_file }} down
Restart=on-failure
RestartSec=10s
User={{ ollama_primary_user }}
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
