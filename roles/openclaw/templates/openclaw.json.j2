// OpenClaw Gateway Configuration
// Managed by Ansible — do not edit manually
// Full reference: https://docs.openclaw.ai/gateway/configuration-reference
{% set _openclaw_host = openclaw_nginx_server_name | default('localhost') %}
{% set _openclaw_ip = ansible_default_ipv4.address | default('127.0.0.1') %}
{% set _openclaw_default_allowed_origins = [
  'http://' ~ _openclaw_host,
  'http://' ~ _openclaw_host ~ ':80',
  'https://' ~ _openclaw_host,
  'https://' ~ _openclaw_host ~ ':443',
  'http://' ~ _openclaw_ip,
  'http://' ~ _openclaw_ip ~ ':80',
  'https://' ~ _openclaw_ip,
  'https://' ~ _openclaw_ip ~ ':443',
  'http://localhost',
  'http://localhost:80',
  'https://localhost',
  'https://localhost:443'
] %}
{% set _openclaw_effective_allowed_origins = (_openclaw_default_allowed_origins + (openclaw_control_ui_allowed_origins | default([]))) | unique %}
{% set _openclaw_final_allowed_origins = ['*'] if (openclaw_control_ui_allow_all_origins | default(false) | bool) else _openclaw_effective_allowed_origins %}
{
  agents: {
    defaults: {
      workspace: "{{ openclaw_workspace_dir }}",
      skipBootstrap: {{ openclaw_skip_bootstrap | lower }},
      thinkingDefault: "{{ openclaw_thinking_default }}",
      model: {
        primary: "{{ openclaw_provider }}/{{ openclaw_ollama_model }}"
      }
    },
    list: [
      {
        id: "main",
        default: true,
        name: "Main",
        model: {
          primary: "{{ openclaw_provider }}/{{ openclaw_ollama_model }}"
        }
      },
      {
        id: "coding",
        name: "Coding",
        model: {
          primary: "{{ openclaw_provider }}/{{ openclaw_ollama_coding_model }}"
        },
        tools: {
          profile: "coding",
          allow: ["browser"]
        }
      },
      {
        id: "research",
        name: "Research",
        thinkingDefault: "high",
        model: {
          primary: "{{ openclaw_provider }}/{{ openclaw_ollama_research_model }}"
        }
      }
    ]
  },

  bindings: [
    {
      agentId: "main",
      match: {
        channel: "discord",
        guildId: "{{ openclaw_discord_server_id }}",
        peer: { kind: "channel", id: "{{ openclaw_discord_channel_general_id }}" }
      }
    },
    {
      agentId: "coding",
      match: {
        channel: "discord",
        guildId: "{{ openclaw_discord_server_id }}",
        peer: { kind: "channel", id: "{{ openclaw_discord_channel_development_id }}" }
      }
    },
    {
      agentId: "research",
      match: {
        channel: "discord",
        guildId: "{{ openclaw_discord_server_id }}",
        peer: { kind: "channel", id: "{{ openclaw_discord_channel_research_id }}" }
      }
    },
    {
      agentId: "main",
      match: {
        channel: "discord",
        guildId: "{{ openclaw_discord_server_id }}",
        peer: { kind: "channel", id: "{{ openclaw_discord_channel_reports_id }}" }
      }
    }
  ],

  // Inject the remote Ollama host so the built-in Ollama provider connects correctly.
  env: {
    OLLAMA_HOST: "http://{{ openclaw_ollama_host }}:11434"
  },

  channels: {
    discord: {
      enabled: {{ (openclaw_discord_token | default('') | length > 0) | lower }},

      // Bot token read from the .env file at runtime — never stored in plain config.
      token: { source: "env", provider: "default", id: "DISCORD_BOT_TOKEN" },

      // Only listed user IDs may DM the bot.
      dmPolicy: "allowlist",
      allowFrom: {{ openclaw_discord_users | default([]) | to_json }}

      // Guild workspace setup (run interactively after first boot):
      //   openclaw configure
      // or tell the agent:
      //   "Add my Discord Server ID {{ openclaw_discord_server_id }} to the guild allowlist"
    }
  },

  gateway: {
    mode: "local",
    port: {{ openclaw_gateway_port }},
    // Use vars/common/vars.yaml to choose bind mode (loopback or lan).
    bind: "{{ openclaw_gateway_bind }}",
    trustedProxies: {{ openclaw_gateway_trusted_proxies | default([]) | to_json }},
    controlUi: {
      enabled: true,
      basePath: "{{ openclaw_control_ui_base_path }}",
      allowedOrigins: {{ _openclaw_final_allowed_origins | to_json }},
      allowInsecureAuth: {{ openclaw_control_ui_allow_insecure_auth | lower }},
      dangerouslyAllowHostHeaderOriginFallback: {{ openclaw_control_ui_allow_host_header_origin_fallback | lower }}
    }
  }
}
