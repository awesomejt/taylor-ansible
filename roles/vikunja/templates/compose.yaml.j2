services:
  vikunja:
    image: {{ vikunja_image }}
    container_name: {{ vikunja_container_name }}
    restart: {{ vikunja_restart_policy }}
    environment:
      VIKUNJA_SERVICE_PUBLICURL: "{{ vikunja_service_public_url }}"
      VIKUNJA_SERVICE_SECRET: "{{ vikunja_service_secret }}"
      VIKUNJA_SERVICE_ENABLEREGISTRATION: "{{ 'true' if vikunja_service_enable_registration | bool else 'false' }}"
      VIKUNJA_AUTH_LOCAL_ENABLED: "{{ 'true' if vikunja_auth_local_enabled | bool else 'false' }}"
      VIKUNJA_AUTH_LDAP_ENABLED: "{{ 'true' if vikunja_auth_ldap_enabled | bool else 'false' }}"
{% if vikunja_auth_ldap_enabled | bool %}
      VIKUNJA_AUTH_LDAP_HOST: "{{ vikunja_auth_ldap_host }}"
      VIKUNJA_AUTH_LDAP_PORT: "{{ vikunja_auth_ldap_port }}"
      VIKUNJA_AUTH_LDAP_BASEDN: "{{ vikunja_auth_ldap_basedn }}"
      VIKUNJA_AUTH_LDAP_USERFILTER: "{{ vikunja_auth_ldap_userfilter }}"
      VIKUNJA_AUTH_LDAP_USETLS: "{{ 'true' if vikunja_auth_ldap_usetls | bool else 'false' }}"
      VIKUNJA_AUTH_LDAP_VERIFYTLS: "{{ 'true' if vikunja_auth_ldap_verifytls | bool else 'false' }}"
      VIKUNJA_AUTH_LDAP_BINDDN: "{{ vikunja_auth_ldap_binddn }}"
      VIKUNJA_AUTH_LDAP_BINDPASSWORD: "{{ vikunja_auth_ldap_bindpassword }}"
{% endif %}
      VIKUNJA_DATABASE_TYPE: "{{ vikunja_database_type }}"
{% if vikunja_database_type == 'sqlite' %}
      VIKUNJA_DATABASE_PATH: "{{ vikunja_database_path }}"
{% else %}
      VIKUNJA_DATABASE_HOST: "{{ vikunja_database_host }}"
      VIKUNJA_DATABASE_PORT: "{{ vikunja_database_port }}"
      VIKUNJA_DATABASE_DATABASE: "{{ vikunja_database_name }}"
      VIKUNJA_DATABASE_USER: "{{ vikunja_database_user }}"
      VIKUNJA_DATABASE_PASSWORD: "{{ vikunja_database_password }}"
{% endif %}
    volumes:
      - {{ vikunja_files_dir }}:/app/vikunja/files
      - {{ vikunja_db_dir }}:/db
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.vikunja.rule=Host(`{{ vikunja_traefik_hostname }}`)"
      - "traefik.http.routers.vikunja.entrypoints={{ vikunja_traefik_entrypoint }}"
      - "traefik.http.services.vikunja.loadbalancer.server.port=3456"
    networks:
      - traefik_proxy
    pull_policy: always

networks:
  traefik_proxy:
    external: true
