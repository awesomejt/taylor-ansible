general_settings:
  master_key: "{{ litellm_master_key }}"

router_settings:
  fallbacks:
    - "{{ litellm_omlx_primary_model_name }}":
        - "{{ litellm_omlx_secondary_model_name }}"
        - "{{ litellm_model_name }}"
    - "{{ litellm_omlx_secondary_model_name }}":
        - "{{ litellm_omlx_primary_model_name }}"
        - "{{ litellm_model_name }}"
    - "{{ litellm_model_name }}":
        - "{{ litellm_omlx_primary_model_name }}"
        - "{{ litellm_omlx_secondary_model_name }}"
    - "{{ litellm_alias_chat }}":
        - "omlx-secondary-chat"
        - "ollama-chat"
    - "{{ litellm_alias_coding }}":
        - "omlx-secondary-coding"
        - "ollama-coding"
    - "{{ litellm_alias_thinking }}":
        - "omlx-secondary-thinking"
        - "ollama-thinking"

model_list:
  - model_name: "{{ litellm_alias_chat }}"
    litellm_params:
      model: "openai/{{ litellm_omlx_primary_chat_model }}"
      api_base: "{{ litellm_omlx_primary_base_url }}"
      api_key: "{{ litellm_omlx_api_key }}"
  - model_name: "{{ litellm_alias_coding }}"
    litellm_params:
      model: "openai/{{ litellm_omlx_primary_coding_model }}"
      api_base: "{{ litellm_omlx_primary_base_url }}"
      api_key: "{{ litellm_omlx_api_key }}"
  - model_name: "{{ litellm_alias_thinking }}"
    litellm_params:
      model: "openai/{{ litellm_omlx_primary_thinking_model }}"
      api_base: "{{ litellm_omlx_primary_base_url }}"
      api_key: "{{ litellm_omlx_api_key }}"
  - model_name: "omlx-primary-chat"
    litellm_params:
      model: "openai/{{ litellm_omlx_primary_chat_model }}"
      api_base: "{{ litellm_omlx_primary_base_url }}"
