upstream ollama_upstream {
  # Primary endpoint (Macbook Pro)
  server {{ (openwebui_ollama_primary_base_url | regex_replace('^https?://', '') | regex_replace('/+$', '')) }} max_fails=3 fail_timeout=30s;
  # Backup endpoint (Mac Mini)
  server {{ (openwebui_ollama_fallback_base_url | regex_replace('^https?://', '') | regex_replace('/+$', '')) }} backup;
  keepalive 16;
}

server {
  listen {{ openwebui_ollama_proxy_listen_port }};

  location / {
    proxy_pass http://ollama_upstream;
    proxy_http_version 1.1;
    proxy_set_header Connection "";
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 3s;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;
    proxy_next_upstream error timeout invalid_header http_500 http_502 http_503 http_504;
    proxy_next_upstream_tries 2;
  }
}
