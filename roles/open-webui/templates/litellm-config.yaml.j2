      model: "openai/{{ openwebui_litellm_omlx_primary_thinking_model }}"
      api_base: "{{ openwebui_litellm_omlx_primary_base_url }}"
      api_key: "{{ openwebui_litellm_omlx_api_key }}"
  - model_name: "omlx-secondary-chat"
    litellm_params:
      model: "openai/{{ openwebui_litellm_omlx_secondary_chat_model }}"
      api_base: "{{ openwebui_litellm_omlx_secondary_base_url }}"
