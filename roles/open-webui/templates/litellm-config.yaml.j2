general_settings:
  master_key: "{{ openwebui_litellm_master_key }}"

router_settings:
  fallbacks:
    - "{{ openwebui_litellm_omlx_primary_model_name }}":
        - "{{ openwebui_litellm_omlx_secondary_model_name }}"
        - "{{ openwebui_litellm_model_name }}"
    - "{{ openwebui_litellm_omlx_secondary_model_name }}":
        - "{{ openwebui_litellm_omlx_primary_model_name }}"
        - "{{ openwebui_litellm_model_name }}"
    - "{{ openwebui_litellm_model_name }}":
        - "{{ openwebui_litellm_omlx_primary_model_name }}"
        - "{{ openwebui_litellm_omlx_secondary_model_name }}"
    - "{{ openwebui_litellm_alias_chat }}":
        - "omlx-secondary-chat"
        - "ollama-chat"
    - "{{ openwebui_litellm_alias_coding }}":
        - "omlx-secondary-coding"
        - "ollama-coding"
    - "{{ openwebui_litellm_alias_thinking }}":
        - "omlx-secondary-thinking"
        - "ollama-thinking"

model_list:
  - model_name: "{{ openwebui_litellm_alias_chat }}"
    litellm_params:
      model: "openai/{{ openwebui_litellm_omlx_primary_chat_model }}"
      api_base: "{{ openwebui_litellm_omlx_primary_base_url }}"
      api_key: "{{ openwebui_litellm_omlx_api_key }}"
  - model_name: "{{ openwebui_litellm_alias_coding }}"
    litellm_params:
      model: "openai/{{ openwebui_litellm_omlx_primary_coding_model }}"
      api_base: "{{ openwebui_litellm_omlx_primary_base_url }}"
      api_key: "{{ openwebui_litellm_omlx_api_key }}"
  - model_name: "{{ openwebui_litellm_alias_thinking }}"
    litellm_params:
      model: "openai/{{ openwebui_litellm_omlx_primary_thinking_model }}"
      api_base: "{{ openwebui_litellm_omlx_primary_base_url }}"
      api_key: "{{ openwebui_litellm_omlx_api_key }}"
  - model_name: "omlx-primary-chat"
    litellm_params:
      model: "openai/{{ openwebui_litellm_omlx_primary_chat_model }}"
      api_base: "{{ openwebui_litellm_omlx_primary_base_url }}"
      api_key: "{{ openwebui_litellm_omlx_api_key }}"
  - model_name: "omlx-primary-coding"
    litellm_params:
      model: "openai/{{ openwebui_litellm_omlx_primary_coding_model }}"
      api_base: "{{ openwebui_litellm_omlx_primary_base_url }}"
      api_key: "{{ openwebui_litellm_omlx_api_key }}"
  - model_name: "omlx-primary-thinking"
