services:
  open-webui:
    image: {{ openwebui_image }}
    container_name: {{ openwebui_container_name }}
    restart: unless-stopped
{% if not openwebui_nginx_enable | bool %}
    ports:
      - "{{ openwebui_host_port }}:8080"
{% endif %}
    volumes:
      - {{ openwebui_data_dir }}:/app/backend/data
    environment:
{% if openwebui_ollama_failover_enabled | bool %}
      OLLAMA_BASE_URL: "http://{{ openwebui_ollama_proxy_container_name }}:{{ openwebui_ollama_proxy_listen_port }}"
{% else %}
      OLLAMA_BASE_URL: "{{ openwebui_ollama_base_url }}"
{% endif %}
    pull_policy: always

{% if openwebui_ollama_failover_enabled | bool %}
  ollama-proxy:
    image: nginx:stable-alpine
    container_name: {{ openwebui_ollama_proxy_container_name }}
    restart: unless-stopped
    volumes:
      - {{ openwebui_ollama_proxy_conf_path }}:/etc/nginx/conf.d/default.conf:ro
    pull_policy: always
{% endif %}

{% if openwebui_nginx_enable | bool %}
  nginx:
    image: {{ openwebui_nginx_image }}
    container_name: {{ openwebui_nginx_container_name }}
    restart: unless-stopped
    depends_on:
      - open-webui
    ports:
      - "{{ openwebui_nginx_http_port }}:80"
{% if openwebui_nginx_ssl_enable | bool %}
      - "{{ openwebui_nginx_https_port }}:443"
{% endif %}
    volumes:
      - {{ openwebui_nginx_conf_path }}:/etc/nginx/conf.d/default.conf:ro
{% if openwebui_nginx_ssl_enable | bool %}
      - {{ openwebui_nginx_ssl_cert_path }}:{{ openwebui_nginx_ssl_cert_path }}:ro
      - {{ openwebui_nginx_ssl_key_path }}:{{ openwebui_nginx_ssl_key_path }}:ro
{% endif %}
    pull_policy: always
{% endif %}
