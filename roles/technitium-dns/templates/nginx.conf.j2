{% if technitium_nginx_ssl_enable | bool %}
server {
  listen {{ technitium_nginx_http_port }};
  server_name {{ technitium_nginx_server_name }};
  return 301 https://$host$request_uri;
}

server {
  listen {{ technitium_nginx_https_port }} ssl;
  server_name {{ technitium_nginx_server_name }};

  ssl_certificate {{ technitium_nginx_ssl_cert_file }};
  ssl_certificate_key {{ technitium_nginx_ssl_key_file }};
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;
  ssl_prefer_server_ciphers on;

{% else %}
server {
  listen {{ technitium_nginx_http_port }};
  server_name {{ technitium_nginx_server_name }};

{% endif %}
  location / {
    proxy_pass http://127.0.0.1:{{ technitium_nginx_backend_port }};
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_read_timeout 86400;
  }
}
