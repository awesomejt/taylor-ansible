[[servers]]
host = "{{ grafana_ldap_host }}"
port = {{ grafana_ldap_port }}
use_ssl = {{ 'true' if grafana_ldap_use_ssl | bool else 'false' }}
start_tls = {{ 'true' if grafana_ldap_start_tls | bool else 'false' }}
ssl_skip_verify = {{ 'true' if grafana_ldap_ssl_skip_verify | bool else 'false' }}
bind_dn = "{{ grafana_ldap_bind_dn }}"
bind_password = {{ grafana_ldap_bind_password | to_json }}
search_filter = "{{ grafana_ldap_search_filter }}"
search_base_dns = [
{% for basedn in grafana_ldap_search_base_dns %}
  "{{ basedn }}"{% if not loop.last %},{% endif %}
{% endfor %}
]

[servers.attributes]
name = "givenName"
surname = "sn"
username = "uid"
member_of = "memberOf"
email = "mail"

[[servers.group_mappings]]
group_dn = "*"
org_role = "Viewer"
grafana_admin = false
